{
  "name": "@pern-monorepo/backend",
  "version": "1.0.0",
  "description": "Node.js Restful CRUD API with Node.js, Express and PostgreSQL",
  "main": "server.js",
  "scripts": {
    "start": "npx env-cmd -f ./.env node server",
    "start:prod": "npx env-cmd -f ./.env node -r newrelic server",
    "start:nr": "npx env-cmd -f ./.env node -r newrelic server",
    "start:nr-deploy": "npx env-cmd -f ./.env node -r newrelic server \n newrelic entity deployment create --guid INSERT_YOUR_GUID_HERE --version 1.0.0 --changelog ADD_YOUR_CHANGELOG_HERE",
    "start:scenario-clean": "npx env-cmd -f ./.env -f ./.env.scenario-clean node -r newrelic server \n newrelic entity deployment create --guid INSERT_YOUR_GUID_HERE --version 1.0.0",
    "start:scenario-low": "npx env-cmd -f ./.env -f ./.env.scenario-low node -r newrelic server",
    "start:scenario-high": "npx env-cmd -f ./.env -f ./.env.scenario-high node -r newrelic server",
    "start:scenario-db": "npx env-cmd -f ./.env -f ./.env.scenario-db node -r newrelic server",
    "rollback:from-high": "npx env-cmd -f ./.env -f ./.env.scenario-low node -r newrelic server",
    "rollback:from-low": "npx env-cmd -f ./.env -f ./.env.scenario-clean node -r newrelic server",
    "rollback:all": "npx env-cmd -f ./.env -f ./.env.scenario-clean node -r newrelic server",
    "load": "npx load-generator",
    "load:baseline": "npx load-generator",
    "load:errors-low": "sh load-gen-errors-low.sh",
    "load:errors-high": "sh load-gen-errors-high.sh",
    "load:errors-db": "sh load-gen-errors-db.sh",
    "initialize": "npx sequelize-cli db:create && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "nodejs",
    "express",
    "rest",
    "api",
    "postgresql"
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.1",
    "load-generator": "^1.3.0",
    "newrelic": "^11.5.0",
    "pg": "^8.8.0",
    "pg-hstore": "^2.3.4",
    "pm2": "^5.2.0",
    "sequelize": "^6.27.0",
    "uuid": "^9.0.1",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "env-cmd": "^10.1.0",
    "sequelize-cli": "^6.6.0"
  }
}
