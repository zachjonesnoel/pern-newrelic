{
  "name": "@pern-monorepo/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "env-cmd -f  ./.env.local vite --host",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "start:nr-deploy": "env-cmd -f  ./.env.local vite --host \n newrelic entity deployment create --guid INSERT_YOUR_GUID_HERE --version 1.0.0",
    "start:scenario-clean": "concurrently \"env-cmd -f ./.env.scenario-clean vite --host\" \"newrelic entity deployment create --guid $Browser_GUID --version 1.0.0\"",
    "start:scenario-low": "env-cmd -f ./.env.scenario-low vite --host",
    "start:scenario-high": "env-cmd -f ./.env.scenario-high vite --host",
    "start:scenario-db": "env-cmd -f ./.env.scenario-db vite --host",
    "rollback:from-high": "env-cmd -f ./.env.scenario-low vite --host",
    "rollback:from-low": "env-cmd -f ./.env.scenario-clean vite --host",
    "rollback:all": "env-cmd -f ./.env.scenario-clean vite --host"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "bootstrap": "^4.6.0",
    "chart.js": "^4.4.9",
    "primeicons": "^6.0.1",
    "primereact": "^8.7.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^6.0.0",
    "react-router-dom": "^6.2.2"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^4.0.0-beta.0",
    "env-cmd": "^10.1.0",
    "eslint": "^8.38.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "vite": "^4.3.0"
  }
}
